# ─── Google Drive ───────────────────────────────────────────────────────────
# Path to your Service Account credentials JSON file
GOOGLE_SERVICE_ACCOUNT_PATH=service_account.json

# (Optional) Restrict sync to a specific Google Drive folder
# Leave blank to sync all accessible files
GDRIVE_FOLDER_ID=

# ─── LLM Backend (choose at least one) ─────────────────────────────────────

# Option 1: Groq (recommended — free, fast, LLaMA-3)
# Get your free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Option 2: HuggingFace Inference API (free tier)
# Get your token at https://huggingface.co/settings/tokens
HF_API_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Option 3: Ollama (local — zero cost, zero API key)
# Install from https://ollama.com, then run: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
